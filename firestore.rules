rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null && 
                    (request.auth.uid == "7pO1pvBK2bRnOerpMgYfU9arVPl1" || 
                     request.auth.token.email == "dobe2589@gmail.com");
    }
  }
}
